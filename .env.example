# =============================================================================
# MCPist Local Development Environment
# =============================================================================
# このファイルを .env.local にコピーして値を設定してください
# supabase start を実行すると SUPABASE_* の値が表示されます

# =============================================================================
# Environment
# =============================================================================
# development | production
ENVIRONMENT=development

# =============================================================================
# App URLs
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:8089
MCP_SERVER_URL=http://localhost:8089
CONSOLE_URL=http://localhost:3000
VAULT_URL=http://localhost:3000/api

# =============================================================================
# Go Server
# =============================================================================
PORT=8089
INSTANCE_ID=local
INSTANCE_REGION=local

# =============================================================================
# Gateway Secret (Worker → Go Server 認証)
# =============================================================================
# Worker の .dev.vars と同じ値を設定
GATEWAY_SECRET=your-gateway-secret

# =============================================================================
# Internal Service Key (Go Server ↔ Console 通信)
# =============================================================================
INTERNAL_SECRET=your-internal-secret
INTERNAL_SERVICE_KEY=your-internal-service-key

# =============================================================================
# Supabase (supabase start で取得)
# =============================================================================
SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# =============================================================================
# External API Keys (必要に応じて設定)
# =============================================================================
# NOTION_TOKEN=your-notion-token
# GITHUB_TOKEN=your-github-token
# JIRA_DOMAIN=your-jira-domain
# JIRA_EMAIL=your-jira-email
# JIRA_API_TOKEN=your-jira-api-token
