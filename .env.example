# MCPist Local Development Environment Variables
#
# Copy this file to .env and fill in the values
# Run `supabase start` to get SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY

# Supabase (from `supabase start` output)
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Internal Service Key (for Go Server <-> Console communication)
INTERNAL_SERVICE_KEY=dev-internal-key

# URLs (override for production)
# NEXT_PUBLIC_APP_URL=https://console.mcpist.app
# NEXT_PUBLIC_MCP_SERVER_URL=https://mcp.mcpist.app
# NEXT_PUBLIC_SUPABASE_URL=https://xstfrjvgpqxvyuochtss.supabase.co
