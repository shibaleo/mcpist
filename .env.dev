# =============================================================================
# MCPist Local Development Environment Template
# =============================================================================
# このファイルをコピーして .env.local を作成し、プレースホルダを実際の値に置き換えてください
# cp .env.dev .env.local
#
# .env.local は .gitignore に含まれているためコミットされません
# .env.dev はテンプレートとして git に登録されています

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# ローカル開発: docker compose で起動する PostgreSQL (pnpm dev で自動起動)
DATABASE_URL=postgresql://postgres:postgres@localhost:57432/mcpist?sslmode=disable&search_path=mcpist
# リモート (Neon): 以下を .env.local で上書き
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_ENDPOINT.neon.tech/neondb?sslmode=require&search_path=mcpist

# =============================================================================
# Clerk (Authentication)
# =============================================================================
# Clerk ダッシュボードから取得して設定
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_yOuRcLeRkPuBLiShAbLeKeY
CLERK_SECRET_KEY=sk_test_yOuRcLeRkSeCrEtKeY
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# =============================================================================
# Cloudflare (DNS and API Gateway)
# =============================================================================
CLOUDFLARE_API_TOKEN=yOuRcLoUdFlArEaPiToKeN
CLOUDFLARE_ACCOUNT_ID=yOuRaCcOuNtId
CLOUDFLARE_ZONE_ID=yOuRzOnEiD

# =============================================================================
# Gateway Auth (Worker → Go Server JWT)
# =============================================================================
# Ed25519 seed (32 bytes, base64) — Worker が署名、Go Server が JWKS で検証
GATEWAY_SIGNING_KEY=rAnDoMbAsE64sEeD32bYtEsHeRe+AAAAAAAAAA=
# Worker の JWKS URL (Go Server が公開鍵をフェッチ)
WORKER_JWKS_URL=http://localhost:8787/.well-known/jwks.json

# =============================================================================
# Admin (comma-separated email addresses)
# =============================================================================
ADMIN_EMAILS=admin@example.com

# =============================================================================
# Local Development URLs
# =============================================================================
SERVER_URL=http://localhost:8089
SERVER_JWKS_URL=http://localhost:8089/.well-known/jwks.json
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:8787

# =============================================================================
# Go Server
# =============================================================================
API_KEY_PRIVATE_KEY=rAnDoMbAsE64sEeDhErE=

# =============================================================================
# Credential Encryption (Server)
# =============================================================================
# AES-256-GCM key for encrypting stored credentials (32 bytes, base64)
CREDENTIAL_ENCRYPTION_KEY=rAnDoMbAsE64eNcRyPtIoNkEy32bYtEs=

# =============================================================================
# OAuth State CSRF Protection (Console)
# =============================================================================
# HMAC-SHA256 secret for signing OAuth state parameters (32 bytes, base64)
OAUTH_STATE_SECRET=rAnDoMbAsE64oAuThStAtEsEcReT32bYtEs=

# =============================================================================
# OAuth App Credentials
# =============================================================================
# 各プロバイダの client_id / client_secret は DB (oauth_apps テーブル) で一元管理。
# admin API (PUT /v1/admin/oauth/apps/{provider}) で登録・更新する。
# 環境変数での個別設定は不要。

# =============================================================================
# Grafana Loki (Observability)
# =============================================================================
GRAFANA_LOKI_URL=https://logs-prod-xxx.grafana.net
GRAFANA_LOKI_USER=yOuRlOkIuSeRiD
GRAFANA_LOKI_API_KEY=glc_yOuRlOkIaPiKeY
