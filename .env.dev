# =============================================================================
# MCPist Local Development Environment Template
# =============================================================================
# このファイルをコピーして .env.local を作成し、プレースホルダを実際の値に置き換えてください
# cp .env.dev .env.local
#
# .env.local は .gitignore に含まれているためコミットされません
# .env.dev はテンプレートとして git に登録されています

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development

# =============================================================================
# Database (Go Server direct connection via GORM)
# =============================================================================
# ローカル: supabase start で起動した PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:57432/postgres?search_path=mcpist
# リモート (dev): Supabase hosted DB
SUPABASE_PROJECT_REF=yOuRpRoJeCtReF
SUPABASE_DB_PASSWORD=yOuRdBpAsSwOrD

# =============================================================================
# Clerk (Authentication)
# =============================================================================
# Clerk ダッシュボードから取得して設定
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_yOuRcLeRkPuBLiShAbLeKeY
CLERK_SECRET_KEY=sk_test_yOuRcLeRkSeCrEtKeY
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# =============================================================================
# Cloudflare (DNS and API Gateway)
# =============================================================================
CLOUDFLARE_API_TOKEN=yOuRcLoUdFlArEaPiToKeN
CLOUDFLARE_ACCOUNT_ID=yOuRaCcOuNtId
CLOUDFLARE_ZONE_ID=yOuRzOnEiD

# =============================================================================
# Gateway / Internal Secrets
# =============================================================================
GATEWAY_SECRET=dev_gateway_secret_for_local
INTERNAL_SECRET=rAnDoMiNtErNaLsEcReTsTrInG

# =============================================================================
# Admin (comma-separated email addresses)
# =============================================================================
ADMIN_EMAILS=admin@example.com

# =============================================================================
# Local Development URLs
# =============================================================================
PRIMARY_API_URL=http://localhost:8089
API_SERVER_JWKS_URL=http://localhost:8089/.well-known/jwks.json
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:8787

# =============================================================================
# Go Server
# =============================================================================
PORT=8089
INSTANCE_ID=local
INSTANCE_REGION=local
API_KEY_PRIVATE_KEY=rAnDoMbAsE64sEeDhErE=

# =============================================================================
