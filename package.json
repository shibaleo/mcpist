{
  "name": "mcpist",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "supabase start && pnpm env:sync && rm -rf apps/console/.next && docker compose --env-file .env.local up -d --build",
    "dev:local": "supabase start && pnpm env:sync && concurrently -n console,server,worker -c blue,green,yellow \"pnpm start:console\" \"pnpm start:server\" \"pnpm start:worker\"",
    "stop": "docker compose down && supabase stop",
    "start:console": "pnpm --filter @mcpist/console dev",
    "start:server": "dotenv -e .env.local -- go run -C apps/server ./cmd/server",
    "start:worker": "pnpm --filter @mcpist/worker dev",
    "logs": "docker compose logs -f",
    "docs:dev": "pnpm --filter @mcpist/docs dev",
    "docs:build": "pnpm --filter @mcpist/docs build",
    "docs:preview": "pnpm --filter @mcpist/docs preview",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "env:sync": "node scripts/sync-env.js"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.14.2",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^8.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
