{
  "name": "mcpist",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "dev:console": "pnpm --filter @mcpist/console dev",
    "dev:server": "pnpm --filter @mcpist/server dev",
    "dev:worker": "pnpm --filter @mcpist/worker dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.14.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
