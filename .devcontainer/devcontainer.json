{
  "name": "MCPist Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true,
      "dockerDashComposeVersion": "v2"
    }
  },

  "forwardPorts": [
    3000,
    8787,
    8081,
    8082,
    8089,
    54321,
    54322,
    54323
  ],

  "portsAttributes": {
    "3000": { "label": "Next.js Console", "onAutoForward": "notify" },
    "8787": { "label": "Cloudflare Worker", "onAutoForward": "notify" },
    "8081": { "label": "API Render (Primary)", "onAutoForward": "silent" },
    "8082": { "label": "API Koyeb (Failover)", "onAutoForward": "silent" },
    "8089": { "label": "Go Server (local)", "onAutoForward": "silent" },
    "54321": { "label": "Supabase API", "onAutoForward": "notify" },
    "54322": { "label": "Supabase DB", "onAutoForward": "silent" },
    "54323": { "label": "Supabase Studio", "onAutoForward": "notify" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker",
        "hashicorp.terraform",
        "redhat.vscode-yaml",
        "GitHub.copilot",
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "go.toolsManagement.autoUpdate": true,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[go]": {
          "editor.defaultFormatter": "golang.go"
        }
      }
    }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "docker compose -f compose/api.yml up -d",

  "remoteUser": "vscode",

  "containerEnv": {
    "DOCKER_HOST": "unix:///var/run/docker.sock"
  }
}
