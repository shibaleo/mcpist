FROM node:22-alpine

WORKDIR /app

# pnpm install
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

# Install dependencies
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile || pnpm install

# Source code (mounted via volume)
COPY . .

EXPOSE 4000

CMD ["pnpm", "dev"]
