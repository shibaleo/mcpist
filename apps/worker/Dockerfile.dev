FROM node:22-slim

WORKDIR /app

# pnpm インストール（slim イメージでは corepack が必要）
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

# 依存関係インストール
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile || pnpm install

# ソースコード
COPY . .

EXPOSE 8787

# wrangler dev --local でNode.jsモードで実行
# --ip 0.0.0.0 でコンテナ外からアクセス可能にする
# 起動前に環境変数から .dev.vars を生成
CMD sh -c '\
  echo "# Generated from environment variables" > .dev.vars && \
  env | grep -E "^(GATEWAY_SECRET|SUPABASE_ANON_KEY|RENDER_URL|KOYEB_URL|SUPABASE_URL|SUPABASE_JWKS_URL)=" >> .dev.vars && \
  npx wrangler dev --local --port 8787 --ip 0.0.0.0'
