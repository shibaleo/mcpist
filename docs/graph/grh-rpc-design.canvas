{
	"nodes":[
		{"id":"grp-mcpist","type":"group","x":-1960,"y":189,"width":3280,"height":891,"color":"3","label":"mcpist"},
		{"id":"grp-oauth","type":"group","x":1960,"y":45,"width":1040,"height":786,"color":"6","label":"OAuth Apps（Router）"},
		{"id":"grp-stripe","type":"group","x":-1000,"y":-769,"width":960,"height":824,"color":"1","label":"Stripe Integration"},
